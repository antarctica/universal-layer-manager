{
  "name": "universal-layer-manager",
  "type": "module",
  "version": "1.0.1",
  "description": "A universal layer manager for map applications",
  "author": {
    "name": "Jonathan Dawe",
    "email": "jonwe@bas.ac.uk"
  },
  "homepage": "https://github.com/antarctica/universal-layer-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antarctica/universal-layer-manager.git"
  },
  "bugs": {
    "url": "https://github.com/antarctica/universal-layer-manager/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/universal-layer-manager.js",
      "require": "./dist/universal-layer-manager.cjs"
    }
  },
  "main": "./dist/universal-layer-manager.cjs",
  "module": "./dist/universal-layer-manager.js",
  "types": "./dist/universal-layer-manager.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "docs": "typedoc",
    "changelog:release": "changelogen --release --no-commit --no-tag",
    "release": "npm run build && npm publish"
  },
  "dependencies": {
    "@internationalized/date": "^3.10.1",
    "xstate": "^5.24.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@types/node": "^22.19.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitest/coverage-v8": "^4.0.7",
    "camelcase": "^8.0.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.1",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.7"
  }
}